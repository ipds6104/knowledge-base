# ============================================================
# Template .env untuk Knowledge Base BPS Kabupaten Mempawah
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# --- Identitas Pengguna Lokal (WAJIB diisi saat setup laptop baru) ---
# Isi dengan email BPS Anda. Ini digunakan agar AI Agent tahu siapa
# yang menggunakan repo ini di laptop ini.
# Contoh: KB_USER_EMAIL=ihzakarunia@bps.go.id
KB_USER_EMAIL=

# --- Konfigurasi AI Proxy ---
AI_PROXY_URL=https://ai.dvlpid.my.id/v1/chat/completions
AI_API_KEY=
AI_MODEL=gemini-3-flash

# --- Google Sheets (untuk kb sync-sheets) ---
# Isi dengan Spreadsheet ID dari URL Google Sheets Anda
SPREADSHEET_ID=
